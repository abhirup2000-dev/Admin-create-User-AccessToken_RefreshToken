<%- include('layouts/header.ejs') %>
<%- include('layouts/navbar.ejs')  %>

<style>
  .profile-section {
    background: #f0f2f5;
    min-height: 100vh;
    padding: 3rem 0;
  }

  /* ── Profile Card ── */
  .profile-card {
    background: #fff;
    border: none;
    border-radius: 20px;
    box-shadow: 0 2px 16px rgba(0,0,0,0.07);
    overflow: hidden;
    margin-bottom: 2rem;
  }

  .profile-card-top {
    background: linear-gradient(135deg, #4f46e5 0%, #7c3aed 100%);
    padding: 2rem 2rem 3.5rem;
    position: relative;
  }

  .profile-avatar {
    width: 80px;
    height: 80px;
    border-radius: 20px;
    background: rgba(255,255,255,0.2);
    backdrop-filter: blur(6px);
    border: 2px solid rgba(255,255,255,0.35);
    color: #fff;
    font-size: 2rem;
    font-weight: 700;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .profile-name {
    font-size: 1.4rem;
    font-weight: 700;
    color: #fff;
    margin: 0;
  }

  .profile-email {
    font-size: 0.85rem;
    color: rgba(255,255,255,0.75);
    margin: 0.2rem 0 0;
  }

  .role-pill {
    display: inline-block;
    font-size: 0.68rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    padding: 0.28rem 0.75rem;
    border-radius: 50px;
    background: rgba(255,255,255,0.2);
    color: #fff;
    border: 1px solid rgba(255,255,255,0.35);
    margin-top: 0.5rem;
  }

  .profile-card-body {
    padding: 0 2rem 2rem;
    margin-top: -1.5rem;
  }

  /* ── Stat tiles ── */
  .stat-tile {
    background: #fff;
    border: 1.5px solid #ececec;
    border-radius: 14px;
    padding: 1rem 1.2rem;
    height: 100%;
    transition: border-color 0.18s;
  }

  .stat-tile:hover {
    border-color: #4f46e5;
  }

  .stat-label {
    font-size: 0.7rem;
    color: #aaa;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: 0.3rem;
  }

  .stat-value {
    font-size: 0.95rem;
    font-weight: 600;
    color: #1a1a2e;
    margin: 0;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  /* ── Action Cards ── */
  .action-card {
    background: #fff;
    border: 1.5px solid #ececec;
    border-radius: 16px;
    padding: 1.6rem;
    height: 100%;
    transition: transform 0.2s ease, box-shadow 0.2s ease, border-color 0.2s;
    cursor: pointer;
  }

  .action-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 10px 28px rgba(0,0,0,0.1);
    border-color: transparent;
  }

  .action-icon {
    width: 48px;
    height: 48px;
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.4rem;
    margin-bottom: 1rem;
  }

  .action-icon.blue   { background: #eef2ff; color: #4f46e5; }
  .action-icon.green  { background: #f0fdf4; color: #16a34a; }
  .action-icon.amber  { background: #fffbeb; color: #d97706; }

  .action-title {
    font-size: 0.98rem;
    font-weight: 600;
    color: #1a1a2e;
    margin-bottom: 0.3rem;
  }

  .action-desc {
    font-size: 0.8rem;
    color: #6c757d;
    margin: 0;
    line-height: 1.5;
  }
</style>

<section class="profile-section">
  <div class="container-xl">

    <!-- Profile Card -->
    <div class="profile-card">

      <div class="profile-card-top">
        <div class="d-flex align-items-center gap-3">
          <div class="profile-avatar">
            <%= data.name.charAt(0).toUpperCase() %>
          </div>
          <div>
            <p class="profile-name"><%= data.name %></p>
            <p class="profile-email"><%= data.email %></p>
            <span class="role-pill"><%= data.role %></span>
          </div>
        </div>
      </div>

      <div class="profile-card-body">
        <div class="row g-3">

          <div class="col-md-4">
            <div class="stat-tile">
              <div class="stat-label">Employee Code</div>
              <p class="stat-value">#<%= data._id.toString().slice(20, 24).toUpperCase() %></p>
            </div>
          </div>

          <div class="col-md-4">
            <div class="stat-tile">
              <div class="stat-label">Joined On</div>
              <p class="stat-value"><%= data.createdAt ? new Date(data.createdAt).toDateString() : 'N/A' %></p>
            </div>
          </div>

          <div class="col-md-4">
            <div class="stat-tile">
              <div class="stat-label">Email</div>
              <p class="stat-value"><%= data.email %></p>
            </div>
          </div>

        </div>
      </div>

    </div>

    <!-- Action Cards -->
    <div class="row g-4">

      <div class="col-lg-4 col-md-6">
        <div class="action-card">
          <div class="action-icon blue">
            <i class="bi bi-person-fill"></i>
          </div>
          <p class="action-title">My Profile</p>
          <p class="action-desc">View and manage your personal details</p>
        </div>
      </div>

      <div class="col-lg-4 col-md-6">
        <div class="action-card">
          <div class="action-icon green">
            <i class="bi bi-shield-lock-fill"></i>
          </div>
          <p class="action-title">Security</p>
          <p class="action-desc">Update password and secure your account</p>
        </div>
      </div>

      <div class="col-lg-4 col-md-6">
        <div class="action-card">
          <div class="action-icon amber">
            <i class="bi bi-gear-fill"></i>
          </div>
          <p class="action-title">Settings</p>
          <p class="action-desc">Manage your preferences and settings</p>
        </div>
      </div>

    </div>

  </div>
</section>

<%- include('layouts/footer.ejs') %>