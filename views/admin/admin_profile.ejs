<%- include('../layouts/header.ejs') %>

<style>
  body {
    background: linear-gradient(135deg, #667eea, #764ba2);
    min-height: 100vh;
  }

  .profile-wrapper {
    padding: 60px 0;
  }

  .card-glass {
    background: rgba(255, 255, 255, 0.15);
    backdrop-filter: blur(14px);
    border-radius: 20px;
    box-shadow: 0 10px 35px rgba(0,0,0,0.25);
    border: 1px solid rgba(255,255,255,0.2);
  }

  .profile-header {
    text-align: center;
    margin-bottom: 25px;
  }

  .avatar {
    width: 80px;
    height: 80px;
    border-radius: 50%;
    background: rgba(255,255,255,0.3);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 28px;
    font-weight: bold;
    color: #fff;
    margin: 0 auto 10px;
  }

  .title {
    color: #fff;
    font-weight: 600;
  }

  .subtitle {
    color: rgba(255,255,255,0.7);
    font-size: 14px;
  }

  .section-title {
    color: #fff;
    font-size: 14px;
    font-weight: 600;
    margin-bottom: 10px;
  }

  .info-box {
    background: rgba(255,255,255,0.2);
    padding: 10px 14px;
    border-radius: 10px;
    margin-bottom: 10px;
    color: #fff;
    font-size: 14px;
  }

  .form-control {
    border-radius: 12px;
    padding: 12px;
  }

  .btn-custom {
    border-radius: 12px;
    font-weight: 600;
    transition: 0.25s;
  }

  .btn-custom:hover {
    transform: translateY(-1px);
    box-shadow: 0 6px 18px rgba(0,0,0,0.25);
  }
</style>

<div class="container profile-wrapper">
  <div class="row justify-content-center">
    <div class="col-lg-6">

      <div class="card-glass p-4">

        <% if (data) { %>

        <!-- PROFILE HEADER -->
        <div class="profile-header">
          <div class="avatar">
            <%= data.name ? data.name.charAt(0).toUpperCase() : 'A' %>
          </div>
          <h3 class="title"><%= data.name %></h3>
          <p class="subtitle">Admin Account</p>
        </div>

        <!-- PROFILE INFO -->
        <div class="mb-4">
          <p class="section-title">Profile Info</p>

          <div class="info-box">
            <strong>Email:</strong> <%= data.email %>
          </div>

          <div class="info-box">
            <strong>Role:</strong> <%= data.role || 'Admin' %>
          </div>
        </div>

        <!-- PASSWORD UPDATE -->
        <div>
          <p class="section-title">Update Password</p>

          <form action="/update/data/<%= data._id %>" method="post">

            <div class="mb-3">
              <input
                type="password"
                class="form-control"
                name="password"
                placeholder="Enter new password (min 6 chars)"
                required
              />
            </div>

            <div class="d-grid">
              <button type="submit" class="btn btn-light btn-custom">
                 Update Password
              </button>
            </div>

          </form>
        </div>

        <% } else { %>

        <div class="text-center text-white">
          <h5>No profile data found</h5>
        </div>

        <% } %>

      </div>

    </div>
  </div>
</div>

<%- include('../layouts/footer.ejs') %>