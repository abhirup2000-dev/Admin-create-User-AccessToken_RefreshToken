<%- include('../layouts/header.ejs') %>
<%- include('../layouts/admin_navbar.ejs') %>

<style>
  .records-section {
    background: #f0f2f5;
    min-height: 100vh;
    padding: 3rem 0;
  }

  .page-title {
    font-size: 1.8rem;
    font-weight: 700;
    color: #1a1a2e;
    margin-bottom: 0.2rem;
  }

  .page-subtitle {
    color: #6c757d;
    font-size: 0.9rem;
    margin: 0;
  }

  .total-badge {
    background: #1a1a2e;
    color: #fff;
    font-size: 0.82rem;
    font-weight: 600;
    padding: 0.5rem 1.1rem;
    border-radius: 50px;
    letter-spacing: 0.04em;
  }

  /* ADD BUTTON */
  .btn-add {
    background: linear-gradient(135deg, #4f46e5, #7c3aed);
    color: #fff;
    font-size: 0.85rem;
    font-weight: 600;
    padding: 0.55rem 1.2rem;
    border-radius: 10px;
    text-decoration: none;
    display: flex;
    align-items: center;
    gap: 0.4rem;
    box-shadow: 0 4px 14px rgba(79,70,229,0.3);
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  .btn-add:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 22px rgba(79,70,229,0.4);
    color: #fff;
  }

  .emp-card {
    background: #fff;
    border: none;
    border-radius: 16px;
    box-shadow: 0 2px 12px rgba(0,0,0,0.07);
    transition: transform 0.2s ease, box-shadow 0.2s ease;
    height: 100%;
    position: relative;
  }

  .emp-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 10px 28px rgba(0,0,0,0.12);
  }

  .emp-avatar {
    width: 50px;
    height: 50px;
    border-radius: 12px;
    background: linear-gradient(135deg, #4f46e5, #7c3aed);
    color: #fff;
    font-size: 1.3rem;
    font-weight: 700;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .emp-name {
    font-size: 1rem;
    font-weight: 600;
    color: #1a1a2e;
    margin: 0;
  }

  .emp-email {
    font-size: 0.78rem;
    color: #6c757d;
    margin: 0;
  }

  .emp-divider {
    border-top: 1px solid #f0f0f0;
    margin: 1rem 0;
  }

  .emp-meta-label {
    font-size: 0.7rem;
    color: #aaa;
    text-transform: uppercase;
  }

  .emp-meta-value {
    font-size: 0.83rem;
    font-weight: 500;
  }

  .role-pill {
    font-size: 0.7rem;
    padding: 0.3rem 0.8rem;
    border-radius: 50px;
    background: #ede9fe;
    color: #5b21b6;
  }

  .btn-edit, .btn-delete {
    flex: 1;
    font-size: 0.82rem;
    padding: 0.5rem;
    border-radius: 10px;
    text-decoration: none;
    display: flex;
    justify-content: center;
    gap: 0.3rem;
  }

  .btn-edit {
    border: 1.5px solid #4f46e5;
    color: #4f46e5;
  }

  .btn-edit:hover {
    background: #4f46e5;
    color: #fff;
  }

  .btn-delete {
    border: 1.5px solid #ef4444;
    color: #ef4444;
  }

  .btn-delete:hover {
    background: #ef4444;
    color: #fff;
  }

  .status-badge {
    position: absolute;
    top: 14px;
    right: 16px;
    font-size: 0.65rem;
    padding: 0.25rem 0.7rem;
    border-radius: 50px;
  }

  .status-badge.active {
    background: #dcfce7;
    color: #166534;
  }

  .status-badge.inactive {
    background: #fee2e2;
    color: #991b1b;
  }

  .empty-card {
    background: #fff;
    border-radius: 16px;
    padding: 4rem;
    text-align: center;
  }
</style>

<section class="records-section">
  <div class="container-xl">

    <!-- HEADER -->
    <div class="d-flex justify-content-between align-items-center mb-4">
      <div>
        <h2 class="page-title">Employee Records</h2>
        <p class="page-subtitle">Manage and view all employee data</p>
      </div>

      <div class="d-flex align-items-center gap-3">
        <a href="/admin/signup-employee" class="btn-add">
          <i class="bi bi-plus-lg"></i> Add Employee
        </a>

        <span class="total-badge">
          Total · <%= data ? data.length : 0 %>
        </span>
      </div>
    </div>

    <div class="row g-4">

      <% if(!data || data.length === 0){ %>

        <div class="col-12">
          <div class="empty-card">
            <h4>No Employees Found</h4>
            <p>Add your first employee to get started</p>

            <a href="/admin/add-employee" class="btn-add mt-3 d-inline-flex">
              <i class="bi bi-plus-lg"></i> Add First Employee
            </a>
          </div>
        </div>

      <% } else { %>

        <% data.forEach((emp) => { %>

        <div class="col-lg-4 col-md-6">
          <div class="emp-card">
            <div class="card-body p-4">

              <!-- FIXED STATUS -->
              <span class="status-badge <%= emp.isActive === 'Active' ? 'active' : 'inactive' %>">
                <%= emp.isActive %>
              </span>

              <div class="d-flex align-items-center gap-3 mb-2">
                <div class="emp-avatar">
                  <%= emp.name.charAt(0).toUpperCase() %>
                </div>
                <div>
                  <p class="emp-name"><%= emp.name %></p>
                  <p class="emp-email"><%= emp.email %></p>
                </div>
              </div>

              <hr class="emp-divider">

              <div class="mb-3">
                <div class="emp-meta-label">Joined</div>
                <div class="emp-meta-value">
                  <%= new Date(emp.createdAt).toDateString() %>
                </div>
              </div>

              <div class="mb-3">
                <span class="role-pill"><%= emp.role %></span>
              </div>

              <% if(emp.role === 'employee'){ %>
              <div class="d-flex gap-2">

                <a href="/toggle-status/<%= emp._id %>" class="btn-edit">
                  <% if(emp.isActive === 'Active'){ %>
                    Block
                  <% } else { %>
                    Unblock
                  <% } %>
                </a>

                <a href="/delete/<%= emp._id %>" class="btn-delete">
                  Delete
                </a>

              </div>
              <% } %>

            </div>
          </div>
        </div>

        <% }) %>

      <% } %>

    </div>
  </div>
</section>

<%- include('../layouts/footer.ejs') %>