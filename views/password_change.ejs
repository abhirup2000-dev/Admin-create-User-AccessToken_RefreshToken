<%- include('layouts/header.ejs') %>

<style>
  .change-pass-section {
    background: #f0f2f5;
    min-height: 100vh;
    display: flex;
    align-items: center;
    padding: 3rem 0;
  }

  .change-pass-card {
    background: #fff;
    border: 1.5px solid #e5e7eb;
    border-radius: 20px;
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.09);
    overflow: hidden;
  }

  .change-pass-top {
    background: linear-gradient(135deg, #4f46e5, #7c3aed);
    padding: 1.8rem 2rem 1.5rem;
    text-align: center;
  }

  .change-pass-icon {
    width: 48px;
    height: 48px;
    border-radius: 13px;
    background: rgba(255, 255, 255, 0.2);
    border: 1.5px solid rgba(255, 255, 255, 0.3);
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 0.9rem;
    font-size: 1.3rem;
    color: #fff;
  }

  .change-pass-title {
    font-size: 1.15rem;
    font-weight: 700;
    color: #fff;
    margin: 0;
    letter-spacing: -0.02em;
  }

  .change-pass-sub {
    font-size: 0.78rem;
    color: rgba(255, 255, 255, 0.65);
    margin: 0.25rem 0 0;
  }

  .change-pass-body {
    padding: 2rem;
  }

  .input-label {
    display: block;
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.07em;
    color: #1a1a2e;
    margin-bottom: 0.4rem;
  }

  .input-group-custom {
    position: relative;
  }

  .input-icon {
    position: absolute;
    left: 0.9rem;
    top: 50%;
    transform: translateY(-50%);
    color: #9ca3af;
    font-size: 0.95rem;
    z-index: 2;
    pointer-events: none;
  }

  .input-group-custom input {
    width: 100%;
    padding: 0.65rem 0.9rem 0.65rem 2.4rem;
    font-size: 0.88rem;
    border: 1.5px solid #e5e7eb;
    border-radius: 10px;
    color: #1a1a2e;
    background: #fafafa;
    transition:
      border-color 0.18s,
      box-shadow 0.18s,
      background 0.18s;
    outline: none;
  }

  .input-group-custom input:focus {
    border-color: #4f46e5;
    background: #fff;
    box-shadow: 0 0 0 3px rgba(79, 70, 229, 0.1);
  }

  .input-group-custom input::placeholder {
    color: #b0b7c3;
    font-size: 0.85rem;
  }

  .btn-update {
    width: 100%;
    padding: 0.65rem;
    font-size: 0.88rem;
    font-weight: 700;
    color: #fff;
    background: linear-gradient(135deg, #4f46e5, #7c3aed);
    border: none;
    border-radius: 10px;
    cursor: pointer;
    transition:
      opacity 0.18s,
      box-shadow 0.18s,
      transform 0.15s;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
  }

  .btn-update:hover {
    opacity: 0.92;
    box-shadow: 0 6px 18px rgba(79, 70, 229, 0.35);
  }

  .btn-update:active {
    transform: scale(0.98);
  }

  .pass-hint {
    font-size: 0.75rem;
    color: #9ca3af;
    margin-top: 0.5rem;
    display: flex;
    align-items: center;
    gap: 0.3rem;
  }
</style>

<section class="change-pass-section">
  <div class="container">
    <div class="row justify-content-center">
      <div class="col-lg-4 col-md-6 col-12">
        <div class="change-pass-card">
          <div class="change-pass-top">
            <div class="change-pass-icon">
              <i class="bi bi-key-fill"></i>
            </div>
            <p class="change-pass-title">Change Password</p>
            <p class="change-pass-sub">Set a new secure password</p>
          </div>

          <div class="change-pass-body">
            <form action="/create/change-password" method="post">
              <div class="mb-4">
                <label class="input-label" for="password">New Password</label>
                <div class="input-group-custom">
                  <i class="bi bi-lock input-icon"></i>
                  <input
                    type="password"
                    name="password"
                    id="password"
                    placeholder="Enter new password"
                    required
                  />
                </div>
                <p class="pass-hint">
                  <i class="bi bi-info-circle"></i>
                  Use at least 8 characters with letters and numbers.
                </p>
              </div>

              <button type="submit" class="btn-update">
                <i class="bi bi-check-lg"></i> Update Password
              </button>
            </form>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<%- include('layouts/footer.ejs') %>
